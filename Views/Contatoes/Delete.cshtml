@model Galoto.Models.Contato

@{
    ViewData["Title"] = "Excluir Contato";
}

<h1>Excluir Contato</h1>

<h3>Tem certeza que deseja excluir este contato?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Nome)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Nome)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Telefone)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Telefone)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Email)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Email)</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Excluir</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>