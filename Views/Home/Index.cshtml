@{
    ViewData["Title"] = "Início";
}

<div class="text-center mb-5">
    <h1 class="display-4 text-primary"><i class="bi bi-box-seam"></i> Galoto</h1>
    <p class="lead text-muted">Sistema de gerenciamento</p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Contatoes" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex p-3 mb-3">
                        <i class="bi bi-people text-primary" style="font-size: 2rem;"></i>
                    </div>
                    <h5 class="card-title text-dark">Contatos</h5>
                    <p class="card-text text-muted small">Gerencie sua agenda de contatos</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Categorias" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex p-3 mb-3">
                        <i class="bi bi-tags text-success" style="font-size: 2rem;"></i>
                    </div>
                    <h5 class="card-title text-dark">Categorias</h5>
                    <p class="card-text text-muted small">Organize seus produtos por categoria</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Produtos" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex p-3 mb-3">
                        <i class="bi bi-box text-warning" style="font-size: 2rem;"></i>
                    </div>
                    <h5 class="card-title text-dark">Produtos</h5>
                    <p class="card-text text-muted small">Cadastre e gerencie produtos</p>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>